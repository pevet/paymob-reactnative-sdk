# Paymob SECRET key — server-side only, never ship in the app.
PAYMOB_SECRET_KEY=

# Optional: HMAC secret from the Paymob dashboard. If set, the webhook verifies
# the signature and rejects mismatches. Leave empty to skip verification.
PAYMOB_HMAC_SECRET=

# Public origin Paymob can reach for the webhook (e.g. an ngrok/cloudflared
# https url). notification_url becomes <PUBLIC_URL>/paymob/webhook.
# Leave unset for local-only testing (webhooks won't be delivered).
PUBLIC_URL=

PORT=3000
